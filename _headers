# Cloudflare Pages response headers.
# Keep HTML fresh, cache static assets aggressively, and add lightweight security headers.

/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin

# HTML must revalidate so deploys reach returning visitors immediately.
/
  Cache-Control: public, max-age=0, must-revalidate
/index.html
  Cache-Control: public, max-age=0, must-revalidate
/sgnoogle.html
  Cache-Control: public, max-age=0, must-revalidate

# Static brand/media assets: nella pratica vengono aggiornati IN PLACE a parità
# di nome (es. avatar-real.webp ricompresso) → niente immutable/1 anno, o i
# visitatori di ritorno restano sulla versione vecchia fino a un anno.
# Un giorno di cache + SWR tiene la velocità senza congelare gli asset.
/assets/*
  Cache-Control: public, max-age=86400, stale-while-revalidate=2592000

# PWA/search helper files can be cached briefly, but should update within a day.
/site.webmanifest
  Cache-Control: public, max-age=86400
/robots.txt
  Cache-Control: public, max-age=86400
/sitemap.xml
  Cache-Control: public, max-age=86400
